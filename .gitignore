# OS
.DS_Store

# Node / web
node_modules/
apps/web/dist/
apps/web/dev-dist/
*.local

# Java / Spring
apps/api/build/
apps/api/.gradle/
apps/api/bin/

# Env / secrets
.env
.env.*
!.env.example
apps/api/secrets/
# GoogleService-Info.plist IS committed (wired into the Xcode App target as a
# required resource so Xcode Cloud / CI archives can build it). Its iOS API key
# is not a real secret — it ships in every app bundle — restrict it in Google
# Cloud (iOS bundle id + FCM) for actual protection.
**/google-services.json
**/AuthKey_*.p8

# Logs
*.log
npm-debug.log*

# IDE
.idea/
.vscode/
*.iml
