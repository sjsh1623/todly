<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template for the iOS Firebase config.

  The real GoogleService-Info.plist is gitignored (never commit it). To set up:
    1. Firebase console → Project settings → your iOS app → Download GoogleService-Info.plist
    2. Save it next to this file as: GoogleService-Info.plist
    3. It is already wired into the Xcode "App" target; FirebaseApp.configure()
       (see AppDelegate.swift) reads it automatically at launch.

  Note: an iOS Firebase API key ships inside the app bundle and is not a
  classic secret — protect it with key restrictions in Google Cloud
  (Application restriction = iOS bundle id, API restriction = FCM only),
  and rotate it if it was ever exposed.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>YOUR_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>YOUR_SENDER_ID</string>
	<key>PROJECT_ID</key>
	<string>your-project-id</string>
	<key>STORAGE_BUCKET</key>
	<string>your-project-id.firebasestorage.app</string>
	<key>GOOGLE_APP_ID</key>
	<string>1:YOUR_SENDER_ID:ios:YOUR_APP_ID</string>
	<key>BUNDLE_ID</key>
	<string>today.mohe.todly</string>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>PLIST_VERSION</key>
	<string>1</string>
</dict>
</plist>
