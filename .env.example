# ===== Database (PostgreSQL 16) =====
POSTGRES_DB=todly
POSTGRES_USER=todly
POSTGRES_PASSWORD=todly_dev_pw
DB_URL=jdbc:postgresql://db:5432/todly

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== Auth / JWT =====
JWT_SECRET=change-me-in-prod-please-32bytes-minimum
JWT_ACCESS_TTL=900          # 15 min (seconds)
JWT_REFRESH_TTL=1209600     # 14 days (seconds)

# ===== OAuth (Apple / Google OIDC) =====
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Web Push (VAPID) =====
PUSH_VAPID_PUBLIC=
PUSH_VAPID_PRIVATE=

# ===== Object storage (photos — v2.0) =====
S3_ENDPOINT=
S3_BUCKET=todly-photos
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ===== Frontend (Vite) =====
VITE_API_BASE_URL=/api/v1
VITE_WS_URL=/ws
